# Copy to .env and adjust (load with your server or export in shell)
AUBASE_DB_HOST=127.0.0.1
AUBASE_DB_PORT=3306
AUBASE_DB_NAME=aubase
AUBASE_DB_USER=root
AUBASE_DB_PASS=

# Legacy demo dataset "current" time (YYYY-MM-DD)
AUBASE_DEMO_NOW=2001-12-14

# Optional: allow browser public/import.php?key=... (empty = CLI only; CLI: php scripts/import.php)
AUBASE_IMPORT_KEY=

# Email verification: set BOTH to send “verify your email” after sign-up (required before login).
# Leave MAIL_FROM empty for local dev → accounts activate immediately without sending mail.
# Password reset needs the same vars + DB columns: php database/migrate_password_reset.php
# Account settings / soft-delete: php database/migrate_account_settings.php (User.created_at, User.deleted_at)
# AUBASE_BASE_URL=http://localhost:8080
# AUBASE_MAIL_FROM="AuBase <noreply@yourdomain.com>"
